<div class="modal fade" id="type-payment-choice">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
     <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title">Choix du mode de paiement</h4>
    </div>
      <div class="modal-body">

        <div class="row">
            <div class="col col-md-7">
                <div class="row">
                    <div class="col col-md-12 p-3">
                        <p>Merci d'indiquer le mode de paiement souhaité.</p>
                    </div>
                </div>
                {% for farmPaymentType in farmPaymentTypes %}
                    {% if farmPaymentType.types|length > 1 %}
                        <div class="row mt-4">
                            <div class="col">
                                <b>{{ farmPaymentType.farm.label }}</b>
                            </div>
                        </div>
                        <div class="row mt-4">
                            {% for type in farmPaymentType.types %}
                                <div class="col">
                                    <label>
                                        <input type="radio" name="payment_type_{{ farmPaymentType.farm.id_farm }}" value="{{ type }}" onchange="changePaymentType({{ farmPaymentType.farm.id_farm }}, this.value)" /> {{ type }}
                                    </label>
                                </div>
                    {% endif %}
                {% endfor %}
     
      </div>
    </div>
  </div>
</div>
